# .env.example — copy to .env.development and fill in real values.
# See specs/pelilauta/firebase/spec.md §Environment Variables for the full list.

# Firebase client config (PUBLIC_ vars — safe to expose in the browser bundle)
PUBLIC_apiKey=
PUBLIC_authDomain=
PUBLIC_projectId=
PUBLIC_storageBucket=
PUBLIC_messagingSenderId=
PUBLIC_appId=
PUBLIC_measurementId=
PUBLIC_databaseURL=

# Service-account fields with public values — PUBLIC_ per v20 correction of
# v17's mislabeling. These are invariant public Google endpoints or identifiers,
# not credentials. Only read on the server, but classified PUBLIC_ because the
# values themselves are non-sensitive.
PUBLIC_universe_domain=
PUBLIC_auth_uri=
PUBLIC_token_uri=
PUBLIC_auth_provider_x509_cert_url=

# Firebase Admin SDK service account (SECRET_ vars — server-side only, never in the browser)
SECRET_private_key_id=
SECRET_private_key=
SECRET_client_email=
SECRET_client_id=
# client_x509_cert_url contains the service-account email (same identifier as
# SECRET_client_email), so stays SECRET_ for defense-in-depth.
SECRET_client_x509_cert_url=

# E2E test fixture secret — dev-only, MUST be unset in production.
# Any non-empty string works locally. See specs/pelilauta/session/spec.md §Test-only seed route.
SECRET_e2e_seed_secret=dev-only-not-a-real-secret

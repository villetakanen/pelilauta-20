---
import { getProfile } from "../server/getProfile";
import type { ProfileSummary } from "../server/schemas";

type Props = {
  uid?: string;
  profile?: ProfileSummary;
  anonymousLabel?: string;
};

const { uid, profile, anonymousLabel = "Anonymous" } = Astro.props as Props;

const invalidUid = !uid || uid === "-";
const resolved = profile ?? (invalidUid ? null : await getProfile(uid));
---

{
  resolved ? (
    <a href={`/profiles/${resolved.key}`}>{resolved.nick}</a>
  ) : (
    <span>{anonymousLabel}</span>
  )
}

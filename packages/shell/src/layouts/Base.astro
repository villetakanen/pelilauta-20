---
import { Tray } from "@cyan/index";

interface Props {
  title: string;
  trayExpanded?: boolean;
  trayLabel?: string;
}

const { title, trayExpanded = false, trayLabel = "Menu" } = Astro.props;
const hasTray = Astro.slots.has("tray");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    {hasTray && (
      <Tray expanded={trayExpanded} label={trayLabel}>
        <slot name="tray" />
      </Tray>
    )}
    <slot name="nav" />
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  @import "@cyan/tokens/index.css";
  @import "@cyan/fonts/fonts.css";

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
  }

  body {
    font-family: var(--cyan-font-family);
    font-size: var(--cyan-font-size-md);
    line-height: var(--cyan-line-height-normal);
    color: var(--cyan-on-background);
    background-color: var(--cyan-background);
  }

  main {
    max-width: 72rem;
    margin-inline: auto;
    padding: var(--cyan-space-md);
  }
</style>

---
import AppBar from "../components/AppBar.astro";
import Tray from "../components/Tray.astro";

interface Props {
  title: string;
  shortTitle?: string;
  layout?: "view" | "sidebar" | "editor" | "modal";
  trayLabel?: string;
  backHref?: string;
}

const { title, shortTitle, layout = "view", trayLabel = "Menu", backHref = "/" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class={`layout-${layout}`}>
    {layout === 'sidebar' && (
      <Tray label={trayLabel}>
        <slot name="tray" />
      </Tray>
    )}
    
    <header class="cn-app-header">
      <AppBar 
        title={title} 
        shortTitle={shortTitle} 
        mode={layout === 'modal' ? 'modal' : ''} 
        backHref={backHref}
      >
        <slot name="actions" />
      </AppBar>
    </header>

    <main class="cn-app-main">
      <slot />
    </main>
  </body>
</html>

<style is:global>
  @import "@cyan/tokens/index.css";
  @import "@cyan/fonts/fonts.css";

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
  }

  body {
    margin: 0;
    font-family: var(--cn-font-family, sans-serif);
    font-size: var(--cn-font-size-text, 16px);
    line-height: var(--cn-line-height-text, 1.5);
    color: var(--color-text);
    background-color: var(--color-background);
    
    /* Setup fundamental layout canvas */
    display: grid;
    grid-template-rows: var(--cn-app-bar-height, 4rem) 1fr;
    grid-template-columns: 1fr;
    min-height: 100dvh;
  }

  .cn-app-header {
    grid-row: 1;
    grid-column: 1 / -1;
    z-index: 100;
  }

  .cn-app-main {
    grid-row: 2;
    grid-column: 1 / -1;
    overflow-y: auto;
    overflow-x: hidden;
  }

  /* --- Layout: View --- */
  .layout-view .cn-app-main {
    max-width: 80rem;
    width: 100%;
    margin-inline: auto;
    padding: var(--cn-gap, 1rem);
  }

  /* --- Layout: Sidebar --- */
  @container (min-width: 64rem) {
    /* If we have a Tray physically active in desktop, we pad the main content so they don't overlap.
       Tray logic is handled inside Tray.astro pushing over the rail area */
    .layout-sidebar .cn-app-main {
       /* Tray container logic handles pushing */
       max-width: 80rem;
       width: 100%;
       margin-inline: auto;
       padding: var(--cn-gap, 1rem);
    }
  }

  /* --- Layout: Editor --- */
  .layout-editor {
    /* lock scrolling */
    overflow: hidden; 
  }
  .layout-editor .cn-app-main {
    padding: 0; /* Fully flush rendering to edges */
    max-width: unset;
  }

  /* --- Layout: Modal --- */
  .layout-modal {
    background-color: var(--color-surface-4);
  }
  .layout-modal .cn-app-main {
    background-color: var(--color-background);
    max-width: 42rem;
    width: 100%;
    margin-inline: auto;
    min-height: calc(100dvh - var(--cn-app-bar-height, 4rem));
    border-inline: 1px solid var(--color-border);
    box-shadow: 0 0 2rem var(--color-shadow);
    padding: var(--cn-gap, 1rem);
  }

  /* Cleanup generic mobile edge cases */
  @media (max-width: 63.99rem) {
    .layout-sidebar .cn-app-main,
    .layout-modal .cn-app-main {
      padding: var(--cn-gap, 1rem);
      border-inline: none;
      box-shadow: none;
    }
  }
</style>

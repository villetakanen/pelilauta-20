---
import AppShell from "./AppShell.astro";

interface Props {
  title: string;
  appTitle?: string;
  shortTitle?: string;
  layout?: "view" | "sidebar" | "editor" | "modal";
  trayLabel?: string;
  backHref?: string;
  noun?: string;
  asPageHeading?: boolean;
}

const {
  title,
  appTitle,
  shortTitle,
  layout = "sidebar",
  trayLabel,
  backHref,
  noun,
  asPageHeading,
} = Astro.props;
---

<AppShell
  title={title}
  appTitle={appTitle}
  shortTitle={shortTitle}
  layout={layout}
  trayLabel={trayLabel}
  backHref={backHref}
  noun={noun}
  asPageHeading={asPageHeading}
>
  <slot name="app-background-poster" slot="app-background-poster" />
  <slot name="tray" slot="tray" />
  <slot name="actions" slot="actions" />
  <slot />
</AppShell>

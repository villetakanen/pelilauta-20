---
import fs from "node:fs";
import { icons as managedIcons } from "@myrrys/proprietary-icons";
/**
 * CnIcon.astro - The definitive, source-code-first icon primitive for v20.
 * Inlines SVGs from 3-tiers of registries during SSR.
 */
import { icons as communityIcons } from "@pelilauta/icons";
import { FallbackIcons } from "./CnIconFallback";

interface Props {
  noun: string;
  size?: "xsmall" | "small" | "medium" | "large" | "xlarge";
}

const { noun, size = "medium" } = Astro.props;

interface IconPath {
  d: string;
  fill?: string;
  opacity?: number;
}

interface ResolvedIcon {
  paths?: IconPath[];
  viewBox?: string;
}

// 1. Resolve Tier (Resolution Order: T1 -> T2 -> T3)
let iconData: ResolvedIcon | string | null = null;
let sourceType: "file" | "fallback" = "fallback";

if (communityIcons[noun as keyof typeof communityIcons]) {
  iconData = communityIcons[noun as keyof typeof communityIcons];
  sourceType = "file";
} else if (managedIcons[noun as keyof typeof managedIcons]) {
  iconData = managedIcons[noun as keyof typeof managedIcons];
  sourceType = "file";
} else if (FallbackIcons[noun]) {
  iconData = FallbackIcons[noun];
  sourceType = "fallback";
} else {
  // Absolute fallback to missing glyph
  iconData = FallbackIcons.missing;
  sourceType = "fallback";
}

// 2. Load SVG Source
let content = "";
let viewBox = (iconData as ResolvedIcon)?.viewBox || "0 0 128 128";

if (sourceType === "file" && typeof iconData === "string") {
  try {
    // Read the SVG from disk during SSR
    const rawSvg = fs.readFileSync(iconData, "utf-8");

    // Extract viewBox and internal content (paths/polygons)
    const viewBoxMatch = rawSvg.match(/viewBox="([^"]+)"/);
    if (viewBoxMatch) viewBox = viewBoxMatch[1];

    // Strip the outer <svg> tag and XML artifacts
    content = rawSvg
      .replace(/<\?xml[^>]*\?>/gi, "")
      .replace(/<!DOCTYPE[^>]*>/gi, "")
      .replace(/<svg[^>]*>/i, "")
      .replace(/<\/svg>/i, "");
  } catch (e) {
    // Fail-open to fallback if file is missing
    const fallback = FallbackIcons.missing;
    content = fallback.paths.map((p) => `<path d="${p.d}" fill="currentColor" />`).join("");
    viewBox = fallback.viewBox || "0 0 24 24";
  }
} else if (sourceType === "fallback" && iconData && typeof iconData !== "string") {
  // Render from hardcoded fallback data
  content = iconData
    .paths!.map((p: IconPath) => {
      const fill = p.fill || "currentColor";
      const opacity = p.opacity !== undefined ? ` fill-opacity="${p.opacity}"` : "";
      return `<path d="${p.d}" fill="${fill}"${opacity} />`;
    })
    .join("");
}

// 3. Coordinate CSS Scaling
const sizes: Record<string, string> = {
  xsmall: "var(--cn-icon-size-xsmall)",
  small: "var(--cn-icon-size-small)",
  medium: "var(--cn-icon-size)",
  large: "var(--cn-icon-size-large)",
  xlarge: "var(--cn-icon-size-xlarge)",
};
const calculatedSize = sizes[size] || size;
---
<span class="cn-icon" data-noun={noun} style={`--icon-dim: ${calculatedSize};`}>
  <svg 
    xmlns="http://www.w3.org/2000/svg" 
    viewBox={viewBox} 
    aria-hidden="true"
  >
    <Fragment set:html={content} />
  </svg>
</span>

<style>
  .cn-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--icon-dim);
    height: var(--icon-dim);
    aspect-ratio: 1/1;
    overflow: hidden;
    vertical-align: middle;
  }
  .cn-icon svg {
    width: 100%;
    height: 100%;
    /* Colors are defined by the internal paths (fill=currentColor or branded) */
  }
</style>

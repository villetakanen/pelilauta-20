---
interface Props {
  href: string;
  label: string;
  active?: boolean;
}

const { href, label, active = false } = Astro.props;
---

<a href={href} class:list={["cn-tray-link", { active }]}>
  {label}
</a>

<style>
  .cn-tray-link {
    display: flex;
    align-items: center;
    min-block-size: calc(var(--cn-grid) * 4);
    padding: calc(var(--cn-grid) * 0.5) var(--cn-grid);
    color: var(--color-link);
    text-decoration: none;
    font-size: var(--cn-font-size-text-small, 0.875rem);
    line-height: var(--cn-text-line-height, 1.5);
    border-radius: var(--cn-border-radius-small);
    transition: background-color 0.2s, color 0.2s;
  }

  .cn-tray-link:hover,
  .cn-tray-link:focus {
    background-color: var(--color-hover);
    color: var(--color-text);
    outline: none;
  }

  .cn-tray-link:focus-visible {
    box-shadow: 0 0 0 2px var(--color-link);
    outline-offset: 2px;
  }

  .cn-tray-link.active {
    color: var(--color-text);
    font-weight: 600;
  }
</style>

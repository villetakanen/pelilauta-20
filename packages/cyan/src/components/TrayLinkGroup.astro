---
interface Props {
  ariaLabel?: string;
}

const { ariaLabel = "Secondary Navigation" } = Astro.props;
---

<ul class="cn-tray-link-group" aria-label={ariaLabel}>
  <slot />
</ul>

<style>
  .cn-tray-link-group {
    display: flex;
    flex-direction: column;
    list-style: none;
    margin: 0;
    padding: 0;
    padding-inline-start: calc(var(--cn-grid) * 5);
    gap: calc(var(--cn-grid) * 0.5);
  }

  /* 
     Hides the sub-navigation group when the container (the Tray) 
     is in Rail Mode (collapsed). 
  */
  @container (max-width: 5.5rem) {
    .cn-tray-link-group {
      display: none;
    }
  }
</style>

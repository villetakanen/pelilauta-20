{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "paths": {
      "@cyan/*": ["../../packages/cyan/src/*"],
      "@shell/*": ["../../packages/shell/src/*"]
    }
  },
  "exclude": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "e2e/**",
    "dist/**",
    "../../packages/**/*.test.ts",
    "../../packages/**/*.spec.ts"
  ]
}

---
/**
 * Book.astro — documentation book layout for the cyan-ds site.
 *
 * Contract: specs/cyan-ds/living-style-books/spec.md
 *
 * Composes on Page (from @cyan/layouts). Owns the page H1 + description from
 * frontmatter. By default wraps the MDX slot in a .cn-content-prose section
 * (67ch readability cage). When frontmatter.multipart === true, skips the
 * wrapper so the MDX author can place their own <section class="cn-content-*">
 * shells directly under <main class="cn-app-main">.
 *
 * Navigation tray is delegated to DocsTray (site-wide primitive, not a Book concern).
 *
 * This layout contains no <style> block. All styling (prose readability,
 * typography, spacing) is provided by the DS via .cn-content-prose and
 * typography-semantics.css in packages/cyan.
 */
import Page from "@cyan/layouts/Page.astro";
import DocsTray from "../components/DocsTray.astro";

interface Props {
  frontmatter: {
    title: string;
    description?: string;
    multipart?: boolean;
  };
}

const { frontmatter } = Astro.props;
const { title, description, multipart = false } = frontmatter;

const pathSegments = Astro.url.pathname.split("/").filter(Boolean);
const currentCategory = pathSegments[0] || "";
const formattedCategory = currentCategory.charAt(0).toUpperCase() + currentCategory.slice(1);
const appTitle = formattedCategory ? `Cyan / ${formattedCategory}` : "Cyan Design System";
---

<Page title={title} appTitle={appTitle} shortTitle="Cyan" layout="sidebar">
  <DocsTray slot="tray" />

  {
    multipart ? (
      <header class="cn-content-prose">
        <h1>{title}</h1>
        {description && <p>{description}</p>}
      </header>
      <slot />
    ) : (
      <article class="cn-content-prose">
        <header>
          <h1>{title}</h1>
          {description && <p>{description}</p>}
        </header>
        <slot />
      </article>
    )
  }
</Page>

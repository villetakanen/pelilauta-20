---
import { type CollectionEntry, getCollection } from "astro:content";
import TrayButton from "@cyan/components/TrayButton.astro";
import AppShell from "@cyan/layouts/AppShell.astro";

interface Props {
  frontmatter: {
    title: string;
    description?: string;
  };
}

const { frontmatter } = Astro.props;
const { title, description } = frontmatter;

type DocCategory = "principles" | "styles" | "components" | "addons";

// Fetch and sort collections for the dynamic navigation tray
const sortEntries = (entries: CollectionEntry<DocCategory>[]) =>
  entries.sort(
    (a, b) =>
      (a.data.order ?? 9999) - (b.data.order ?? 9999) || a.data.title.localeCompare(b.data.title),
  );

const principles = sortEntries(await getCollection("principles"));
const styles = sortEntries(await getCollection("styles"));
const components = sortEntries(await getCollection("components"));
const addons = sortEntries(await getCollection("addons"));

const groups: {
  id: DocCategory;
  label: string;
  entries: CollectionEntry<DocCategory>[];
  defaultIcon: string;
}[] = [
  { id: "principles", label: "Principles", entries: principles, defaultIcon: "🎨" },
  { id: "styles", label: "Styles", entries: styles, defaultIcon: "📏" },
  { id: "components", label: "Components", entries: components, defaultIcon: "🧩" },
  { id: "addons", label: "Addons", entries: addons, defaultIcon: "➕" },
];
---

<AppShell title={title} layout="sidebar">
  <div slot="tray" style="display: contents;">
    <TrayButton icon="📖" label="Intro" href="/" active={Astro.url.pathname === '/'} />
    
    {groups.map(group => group.entries.length > 0 && (
      <>
        <h4 class="cn-book-tray-section">{group.label}</h4>
        {group.entries.map(entry => (
          <TrayButton 
            icon={entry.data.icon || group.defaultIcon} 
            label={entry.data.title} 
            href={`/${group.id}/${entry.slug}`} 
            active={Astro.url.pathname.includes(`/${group.id}/${entry.slug}`)} 
          />
        ))}
      </>
    ))}
  </div>

  <article class="cn-book-article">
    <header class="cn-book-header">
      <h1>{title}</h1>
      {description && <p class="description">{description}</p>}
    </header>
    <div class="cn-book-content">
      <slot />
    </div>
  </article>
</AppShell>

<style>
  .cn-book-article {
      max-width: 60rem;
      margin-inline: auto;
      padding: var(--cn-gap);
  }
  .cn-book-header {
      margin-block-end: calc(var(--cn-gap) * 2);
  }
  .description {
    color: var(--color-on-surface-variant);
    font-size: 1.125rem;
    margin-block-start: var(--cn-grid);
    max-width: 40rem;
  }
  h4.cn-book-tray-section {
      margin-block: var(--cn-gap) var(--cn-grid);
      padding-inline: var(--cn-grid);
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      opacity: 0.6;
      transition: opacity 0.2s;
  }
  
  :global(.cn-tray:not(:has(.cn-tray-toggle:checked)) .cn-book-tray-section) {
    @media (min-width: 621px) {
      display: none;
      opacity: 0;
    }
  }
</style>

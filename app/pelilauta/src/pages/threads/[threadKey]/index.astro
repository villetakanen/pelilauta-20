---
// Thread detail page — read-only, anonymous-friendly, SSR with progressive reply hydration.
// Anonymous viewers: full SSR reply list, no JS for the reply list.
// Authenticated viewers: same SSR seed, then ThreadReplies hydrates for realtime updates.
// See specs/pelilauta/threads/spec.md Stage-2 DoD.
// See specs/pelilauta/threads/replies/spec.md §Host page resolves profiles and bodyHtml upstream of ThreadReplies
// See specs/pelilauta/threads/replies/spec.md §Host page parses ?since= into targetFlowTime

import type { Profile } from "@pelilauta/profiles/server";
import { getProfile } from "@pelilauta/profiles/server";
import {
  ThreadDetail,
  ThreadMetadata,
  ThreadReplies,
  ThreadReplySection,
} from "@pelilauta/threads/components";
import type { Thread } from "@pelilauta/threads/server";
import { getChannels, getThread } from "@pelilauta/threads/server";
import { logError } from "@pelilauta/utils/log";
import { markdownToHTML } from "@pelilauta/utils/markdownToHTML";
import { markdownToPlainText } from "@pelilauta/utils/markdownToPlainText";
import { DEFAULT_LOCALE, t } from "../../../i18n";
import Page from "../../../layouts/Page.astro";
import { parseSinceParam } from "./parseSinceParam";
import type { InitialReplyEntry } from "./prepareInitialReplies";
import { prepareInitialReplies } from "./prepareInitialReplies";
import { resolveChannelName } from "./resolveChannelName";

const { threadKey } = Astro.params;

if (!threadKey) {
  Astro.response.status = 404;
}

let thread: Thread | undefined;
let bodyHtml = "";
let error = false;
let initialReplies: InitialReplyEntry[] = [];
let authorProfile: Profile | null = null;
let channelName = "";

const currentUid = Astro.locals.uid ?? null;
const targetFlowTime = parseSinceParam(Astro.request.url);
const locale = DEFAULT_LOCALE;

if (threadKey) {
  try {
    thread = await getThread(threadKey);
    if (thread) {
      // Markdown rendering and upstream data resolution — SSR Data Flow rule.
      // getProfile, getChannels, and prepareInitialReplies run in parallel.
      const ownerUid = thread.owners[0];
      let channels: Awaited<ReturnType<typeof getChannels>>;
      [bodyHtml, initialReplies, authorProfile, channels] = await Promise.all([
        markdownToHTML(thread.markdownContent ?? ""),
        prepareInitialReplies(threadKey),
        getProfile(ownerUid),
        getChannels(),
      ]);
      // Channel display name resolved upstream; falls back to slug when not found.
      channelName = resolveChannelName(thread.channel, channels);
    } else {
      Astro.response.status = 404;
    }
  } catch (e) {
    logError("ThreadDetailPage", e);
    error = true;
  }
}

const title = thread
  ? `${thread.title} — Pelilauta`
  : error
    ? "Pelilauta"
    : "Not found — Pelilauta";

const description = thread
  ? markdownToPlainText(thread.markdownContent ?? "", 160) || thread.title
  : error
    ? "Virhe ladattaessa keskustelua."
    : "Keskustelua ei löytynyt.";
---

<Page title={title} description={description} layout="view" ogType="article">
  {error && <p>{t("pelilauta:error.fetch")}</p>}
  {!error && !thread && <p>{t("pelilauta:error.notFound")}</p>}
  {!error && thread && (
    <div class="cn-content-golden">
      <ThreadDetail thread={thread} bodyHtml={bodyHtml} />
      <aside>
        <ThreadMetadata
          thread={thread}
          authorProfile={authorProfile}
          channelName={channelName}
          locale={locale}
        />
      </aside>
    </div>
  )}
  {!error && thread && (
    <>
      {currentUid ? (
        // Authenticated: ThreadReplySection owns ThreadReplies + ReplyForm in one
        // island so the entries state is shared between the listener and the
        // optimistic-append flow.
        // client:idle is friendlier on FCP — the SSR seed paints first.
        <ThreadReplySection
          client:idle
          threadKey={threadKey!}
          {initialReplies}
          {currentUid}
          {targetFlowTime}
          placeholderText={t("threads:replies.compose.placeholder")}
          frozenNoticeText={t("threads:replies.compose.frozenNotice")}
          errorText={t("threads:replies.compose.error")}
        />
      ) : (
        // Anonymous: pure SSR reply list + static login CTA. No JS bundle shipped.
        <>
          <ThreadReplies
            threadKey={threadKey!}
            {initialReplies}
            currentUid={null}
            {targetFlowTime}
          />
          <a href={`/login?next=/threads/${threadKey}`}>
            {t("threads:replies.compose.loginCta")}
          </a>
        </>
      )}
    </>
  )}
</Page>

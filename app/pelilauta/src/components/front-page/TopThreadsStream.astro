---
// TopThreadsStream — data-bound widget for the front-page Threads region.
//
// Pure SSR: no client: directives, no <style>, no inline styles.
// Errors are isolated — a Firestore failure renders the error block, not a 5xx.
// See specs/pelilauta/front-page/top-threads-stream/spec.md.

import { ThreadCard } from "@pelilauta/threads/components";
import type { Channel, Thread } from "@pelilauta/threads/server";
import { getChannels, getThreads } from "@pelilauta/threads/server";
import { logError } from "@pelilauta/utils/log";
import { t } from "../../i18n";

let threads: Thread[] = [];
let channels: Channel[] = [];
let error = false;

try {
  threads = await getThreads(5);
  channels = await getChannels();
} catch (e) {
  logError("TopThreadsStream", e);
  error = true;
}

function channelIcon(channelSlug: string): string | undefined {
  const channel = channels.find((c) => c.slug === channelSlug);
  return channel?.icon;
}
---

<div>
  <h2>{t("threads:title")}</h2>

  {error && <p>{t("pelilauta:error.fetch")}</p>}

  <div class="cn-card-grid">
    {
      !error &&
        threads.map((thread) => (
          <ThreadCard thread={thread} noun={channelIcon(thread.channel)} />
        ))
    }
  </div>

  <div class="toolbar items-center">
    <a class="button" href="/channels">{t("pelilauta:action.showMore")}</a>
  </div>
</div>

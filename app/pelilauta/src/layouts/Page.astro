---
import ProfileButton from "@cyan/components/ProfileButton.svelte";
import CyanPage from "@cyan/layouts/Page.astro";
import brandImage from "@myrrys/proprietary/juno-viinikka/juno-viinikka-dragon-1.jpg";
import { AuthChrome, AuthHandler } from "@pelilauta/auth/components";
import { getAccount, projectProfileFromClaims } from "@pelilauta/auth/server";
import AppFooter from "../components/footer/AppFooter.astro";

interface Props {
  title: string;
  description: string;
  appTitle?: string;
  shortTitle?: string;
  layout?: "view" | "sidebar" | "editor" | "modal";
  trayLabel?: string;
  backHref?: string;
  noun?: string;
  asPageHeading?: boolean;
  image?: string;
  defaultImage?: string;
  siteName?: string;
  noSharing?: boolean;
  ogType?: "website" | "article";
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
  breadcrumbs?: Array<{ label: string; href: string }>;
}

const { uid, claims } = Astro.locals;
const {
  defaultImage = new URL(brandImage.src, Astro.url.origin).toString(),
  siteName = "Pelilauta",
  ...rest
} = Astro.props;

// Synthesize a profile projection when the SSR identity is resolved; see
// specs/pelilauta/session/spec.md §Data models.
// Frozen status is resolved server-side to avoid flash and ensure fail-safe
// visibility: FABs remain hidden until frozen is authoritatively confirmed.
// specs/pelilauta/session/frozen.md §Fail-Safe Visibility
const profile =
  uid && claims
    ? {
        ...projectProfileFromClaims(claims),
        frozen: (await getAccount(uid))?.frozen ?? false,
      }
    : null;
---

<CyanPage defaultImage={defaultImage} siteName={siteName} {...rest}>
  <slot name="app-background-poster" slot="app-background-poster" />
  <slot name="tray" slot="tray" />
  <slot name="fab-tray" slot="fab-tray" />
  <Fragment slot="footer-body">
    <slot name="footer-body">
      <AppFooter />
    </slot>
  </Fragment>
  <Fragment slot="app-footer-credits">
    <slot name="app-footer-credits">
      <p>
        Background image © Juno Viinikka (
        <a href="https://linktr.ee/junowski">junowski</a>
        )
      </p>
    </slot>
  </Fragment>
  <Fragment slot="actions">
    <slot name="actions" />
    {
      uid && profile ? (
        <AuthChrome client:load ssrProfile={profile} />
      ) : (
        <ProfileButton />
      )
    }
  </Fragment>

  <slot />

  {
    uid && (
      <AuthHandler
        client:load
        ssrUid={uid}
        ssrProfile={profile}
      />
    )
  }
</CyanPage>

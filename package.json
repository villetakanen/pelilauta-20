{
  "name": "pelilauta-20",
  "version": "20.0.0-alpha.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter ./app/pelilauta dev",
    "dev:ds": "pnpm --filter ./app/cyan-ds dev",
    "build": "pnpm --filter './app/*' build",
    "test": "pnpm --filter '*' test",
    "test:e2e": "pnpm --filter './app/*' test:e2e",
    "check": "biome check --write .",
    "check:types": "tsc --noEmit",
    "gen:icons": "node --experimental-strip-types scripts/generate-icon-registry.ts",
    "check:icons": "node --experimental-strip-types scripts/generate-icon-registry.ts --check",
    "seed:e2e": "node --experimental-strip-types packages/firebase/scripts/seed-e2e.ts",
    "verify": "bash scripts/verify.sh",
    "ship": "bash scripts/ship.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "lefthook": "^2.1.4",
    "typescript": "^6.0.2"
  },
  "pnpm": {
    "overrides": {
      "rollup": "4.59.1"
    },
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@firebase/util",
      "esbuild",
      "lefthook",
      "protobufjs",
      "sharp"
    ]
  }
}

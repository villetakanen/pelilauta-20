minimum-release-age=4320
# Hoist transitively-public packages to the top-level node_modules/ so tools
# that expect an npm-flat layout (notably Netlify's zip-it-and-ship-it function
# bundler) can resolve them. Pairs with vite.ssr.external + [functions.ssr]
# external_node_modules for firebase-admin in app/pelilauta/netlify.toml.
# See specs/pelilauta/firebase/spec.md §SSR Safety.
shamefully-hoist=true
